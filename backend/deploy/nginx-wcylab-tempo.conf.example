# Tempo 专用 Nginx 配置模板（当前仅保存，不要在端口未获授权前启用）
# 使用前提：api.wcylab.cn 已解析到服务器，且已获 80/443 端口授权。
# FastAPI 应仅监听 127.0.0.1:3001；证书需先由 certbot 申请。

server {
    listen 80;
    server_name api.wcylab.cn;
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    server_name api.wcylab.cn;
    ssl_certificate /etc/letsencrypt/live/api.wcylab.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.wcylab.cn/privkey.pem;
    client_max_body_size 25m;
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
